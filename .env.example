# === Окружение ===
ENV=dev
DEBUG=false
LOG_LEVEL=INFO

# === Telegram ===
BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://your-tunnel-url.lhr.life

# === LLM Provider (ollama | openai | anthropic) ===
LLM_PROVIDER=ollama

# -- Ollama (для LLM_PROVIDER=ollama) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b-instruct-q8_0
OLLAMA_TIMEOUT=300

# -- OpenAI (для LLM_PROVIDER=openai) --
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# -- Anthropic (для LLM_PROVIDER=anthropic) --
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Storage ===
STORAGE_BACKEND=memory
# DATABASE_URL=postgresql://bot:password@localhost:5432/nicomarket
# REDIS_URL=redis://localhost:6379/0

# === Admin ===
# ADMIN_USER_IDS=[123456789,987654321]
# MANAGER_CHAT_ID=0

# === Postgres (для docker-compose) ===
POSTGRES_PASSWORD=change_me_in_production
REDIS_PASSWORD=change_me_in_production
